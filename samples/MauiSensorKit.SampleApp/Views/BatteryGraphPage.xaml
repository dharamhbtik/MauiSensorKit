<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiSensorKit.SampleApp.ViewModels"
             xmlns:microcharts="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             xmlns:views="clr-namespace:MauiSensorKit.SampleApp.Views"
             x:Class="MauiSensorKit.SampleApp.Views.BatteryGraphPage"
             Title="Battery Monitor">

    <ContentPage.Resources>
        <ResourceDictionary>
            <views:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Current Status -->
        <Grid Grid.Row="0" ColumnDefinitions="*,*,*" Padding="10,5" BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#333333}">
            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                <Label Text="Current %" FontSize="10" TextColor="Gray" HorizontalOptions="Center"/>
                <Label Text="{Binding CurrentPercentage}" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"/>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                <Label Text="State" FontSize="10" TextColor="Gray" HorizontalOptions="Center"/>
                <Label Text="{Binding CurrentState}" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center"/>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                <Label Text="Power" FontSize="10" TextColor="Gray" HorizontalOptions="Center"/>
                <Label Text="{Binding PowerSource}" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

        <!-- Info Row -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" Padding="10,2">
            <Label Grid.Column="0" 
                   Text="{Binding ReadingCount, StringFormat='Readings: {0}'}" 
                   FontSize="12" 
                   TextColor="Gray"/>
            <Label Grid.Column="1" 
                   Text="{Binding RecordingDuration, StringFormat='Duration: {0}'}" 
                   FontSize="12" 
                   TextColor="Gray"
                   HorizontalOptions="End"/>
        </Grid>

        <!-- Chart -->
        <microcharts:ChartView Grid.Row="2" 
                               Chart="{Binding BatteryChart}"
                               IsVisible="{Binding HasData}"
                               Margin="10"/>

        <!-- Empty State -->
        <Label Grid.Row="2" 
               Text="Start recording to collect battery data"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               TextColor="Gray"
               IsVisible="{Binding HasData, Converter={StaticResource InvertedBoolConverter}}"/>

        <!-- Controls -->
        <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" Padding="10" ColumnSpacing="10">
            <Label Grid.Column="0" 
                   Text="Battery % over time (last 60 readings)"
                   VerticalOptions="Center"
                   FontSize="10"
                   TextColor="Gray"/>
            <Button Grid.Column="1" 
                    Text="Refresh" 
                    Command="{Binding RefreshChartCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    FontSize="12"/>
            <Button Grid.Column="2" 
                    Text="Clear" 
                    Command="{Binding ClearDataCommand}"
                    BackgroundColor="{StaticResource Gray400}"
                    TextColor="White"
                    FontSize="12"/>
        </Grid>
    </Grid>

</ContentPage>
