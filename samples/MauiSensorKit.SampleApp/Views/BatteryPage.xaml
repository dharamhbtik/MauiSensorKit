<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiSensorKit.SampleApp.ViewModels"
             xmlns:microcharts="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             xmlns:mauisensorkit="clr-namespace:MauiSensorKit;assembly=MauiSensorKit"
             x:Class="MauiSensorKit.SampleApp.Views.BatteryPage"
             Title="Battery"
             BackgroundColor="#0F0F1A">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="16">

            <!-- SECTION 1: Hero Card -->
            <Frame BackgroundColor="#6C63FF"
                   CornerRadius="16"
                   HasShadow="True"
                   Padding="24">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="4">
                    <!-- Battery Icon and Percentage -->
                    <HorizontalStackLayout Grid.Row="0" Spacing="16" HorizontalOptions="Center">
                        <Label Text="🔋" FontSize="48" />
                        <Label Text="{Binding CurrentSnapshot.ChargePercent, StringFormat='{0:F0}%'}}"
                               FontSize="48"
                               FontAttributes="Bold"
                               TextColor="White" />
                    </HorizontalStackLayout>
                    
                    <!-- Charging Status -->
                    <Label Grid.Row="1"
                           Text="{Binding EstimatedTimeString}"
                           FontSize="16"
                           TextColor="#CCFFFFFF"
                           HorizontalOptions="Center" />
                    
                    <!-- Stats Row -->
                    <HorizontalStackLayout Grid.Row="2" 
                                          Spacing="16" 
                                          HorizontalOptions="Center"
                                          Margin="0,8,0,0">
                        <Label Text="{Binding TemperatureText}" 
                               TextColor="#99FFFFFF"
                               FontSize="12" />
                        <Label Text="{Binding VoltageText}" 
                               TextColor="#99FFFFFF"
                               FontSize="12" />
                        <Label Text="{Binding CurrentText}" 
                               TextColor="#99FFFFFF"
                               FontSize="12" />
                    </HorizontalStackLayout>
                    
                    <!-- Technology and Health Row -->
                    <HorizontalStackLayout Grid.Row="3" 
                                          Spacing="16" 
                                          HorizontalOptions="Center"
                                          Margin="0,4,0,0">
                        <Label Text="{Binding TechnologyText, StringFormat='Tech: {0}'}" 
                               TextColor="#99FFFFFF"
                               FontSize="12" />
                        <Label Text="{Binding HealthText, StringFormat='Health: {0}'}" 
                               TextColor="#99FFFFFF"
                               FontSize="12" />
                    </HorizontalStackLayout>
                </Grid>
            </Frame>

            <!-- SECTION 2: Time Range Selector -->
            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                <Button Text="1H" 
                        Command="{Binding SelectTimeRangeCommand}"
                        CommandParameter="1H" />
                <Button Text="6H" 
                        Command="{Binding SelectTimeRangeCommand}"
                        CommandParameter="6H" />
                <Button Text="24H" 
                        Command="{Binding SelectTimeRangeCommand}"
                        CommandParameter="24H" />
                <Button Text="Session" 
                        Command="{Binding SelectTimeRangeCommand}"
                        CommandParameter="Session" />
            </HorizontalStackLayout>

            <!-- SECTION 3: Timeline Chart -->
            <Frame BackgroundColor="#1A1A2E"
                   CornerRadius="12"
                   Padding="12">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Charge History" 
                           TextColor="#FFFFFF"
                           FontSize="16"
                           FontAttributes="Bold" />
                    <microcharts:ChartView Chart="{Binding TimelineChart}"
                                          HeightRequest="200"
                                          HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Frame>

            <!-- SECTION 4: Analytics Cards -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                <!-- Voltage Card -->
                <Frame Grid.Row="0" Grid.Column="0" 
                       BackgroundColor="#1A1A2E"
                       CornerRadius="12"
                       Padding="16">
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="⚡" FontSize="24" />
                        <Label Text="{Binding VoltageText}" 
                               FontSize="20"
                               TextColor="#FFFFFF"
                               FontAttributes="Bold" />
                        <Label Text="Voltage" 
                               TextColor="#99FFFFFF"
                               FontSize="12" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Current Card -->
                <Frame Grid.Row="0" Grid.Column="1" 
                       BackgroundColor="#1A1A2E"
                       CornerRadius="12"
                       Padding="16">
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="🔋" FontSize="24" />
                        <Label Text="{Binding CurrentText}" 
                               FontSize="20"
                               TextColor="#FFFFFF"
                               FontAttributes="Bold" />
                        <Label Text="Current" 
                               TextColor="#99FFFFFF"
                               FontSize="12" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Temperature Card -->
                <Frame Grid.Row="1" Grid.Column="0" 
                       BackgroundColor="#1A1A2E"
                       CornerRadius="12"
                       Padding="16">
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="🌡️" FontSize="24" />
                        <Label Text="{Binding TemperatureText}" 
                               FontSize="20"
                               TextColor="#FFFFFF"
                               FontAttributes="Bold" />
                        <Label Text="Temperature" 
                               TextColor="#99FFFFFF"
                               FontSize="12" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Technology Card -->
                <Frame Grid.Row="1" Grid.Column="1" 
                       BackgroundColor="#1A1A2E"
                       CornerRadius="12"
                       Padding="16">
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="�" FontSize="24" />
                        <Label Text="{Binding TechnologyText}" 
                               FontSize="20"
                               TextColor="#FFFFFF"
                               FontAttributes="Bold" />
                        <Label Text="Technology" 
                               TextColor="#99FFFFFF"
                               FontSize="12" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Health Card -->
                <Frame Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                       BackgroundColor="#1A1A2E"
                       CornerRadius="12"
                       Padding="16">
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="❤️" FontSize="24" />
                        <Label Text="{Binding HealthText}" 
                               FontSize="20"
                               TextColor="#FFFFFF"
                               FontAttributes="Bold" />
                        <Label Text="Battery Health" 
                               TextColor="#99FFFFFF"
                               FontSize="12" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- SECTION 5: Drain Rate Chart -->
            <Frame BackgroundColor="#1A1A2E"
                   CornerRadius="12"
                   Padding="12">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Drain Rate by Hour" 
                           TextColor="#FFFFFF"
                           FontSize="16"
                           FontAttributes="Bold" />
                    <microcharts:ChartView Chart="{Binding DrainRateChart}"
                                          HeightRequest="150"
                                          HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Frame>

            <!-- SECTION 6: Events Log -->
            <Frame BackgroundColor="#1A1A2E"
                   CornerRadius="12"
                   Padding="12">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Battery Events" 
                           TextColor="#FFFFFF"
                           FontSize="16"
                           FontAttributes="Bold" />
                    
                    <CollectionView ItemsSource="{Binding Events}"
                                   HeightRequest="200"
                                   EmptyView="No battery events yet. Events will appear as your battery changes.">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="mauisensorkit:BatteryEvent">
                                <Grid ColumnDefinitions="Auto,*,Auto" 
                                      Padding="8,4"
                                      ColumnSpacing="12">
                                    <Label Grid.Column="0" 
                                           Text="{Binding Icon}" 
                                           FontSize="20" />
                                    <VerticalStackLayout Grid.Column="1">
                                        <Label Text="{Binding Description}" 
                                               TextColor="#FFFFFF"
                                               FontSize="14" />
                                        <Label Text="{Binding ChargeAtEvent, StringFormat='Battery: {0:P0}'}" 
                                               TextColor="#99FFFFFF"
                                               FontSize="12" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" 
                                           Text="{Binding Timestamp, StringFormat='{0:HH:mm}'}" 
                                           TextColor="#99FFFFFF"
                                           FontSize="12" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
