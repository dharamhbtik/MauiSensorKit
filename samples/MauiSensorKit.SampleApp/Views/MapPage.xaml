<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiSensorKit.SampleApp.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="MauiSensorKit.SampleApp.Views.MapPage"
             Title="Live Route Map"
             BackgroundColor="#0F0F1A">

    <AbsoluteLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">
        
        <!-- Map View - Full screen -->
        <WebView x:Name="SensorMap" 
                 AbsoluteLayout.LayoutBounds="0,0,1,1"
                 AbsoluteLayout.LayoutFlags="All"
                 BackgroundColor="#0F0F1A" />

        <!-- Action FABs (Right side) - Fixed position -->
        <VerticalStackLayout AbsoluteLayout.LayoutBounds="1,0.5,-1,-1"
                            AbsoluteLayout.LayoutFlags="XProportional,YProportional"
                            Spacing="10"
                            Margin="0,0,16,0"
                            HorizontalOptions="End"
                            VerticalOptions="Center">
            <Button x:Name="ZoomInButton"
                   Text="+"
                   FontSize="20"
                   WidthRequest="44"
                   HeightRequest="44"
                   CornerRadius="22"
                   BackgroundColor="#CC1A1A2E"
                   TextColor="#FFFFFF" />
            <Button x:Name="ZoomOutButton"
                   Text="-"
                   FontSize="22"
                   WidthRequest="44"
                   HeightRequest="44"
                   CornerRadius="22"
                   BackgroundColor="#CC1A1A2E"
                   TextColor="#FFFFFF" />
            <Button x:Name="CenterButton"
                   Text="◎"
                   FontSize="16"
                   WidthRequest="44"
                   HeightRequest="44"
                   CornerRadius="22"
                   BackgroundColor="#CC6C63FF"
                   TextColor="#FFFFFF" />
        </VerticalStackLayout>

        <!-- Bottom Panel -->
        <Frame AbsoluteLayout.LayoutBounds="0,1,1,-1"
               AbsoluteLayout.LayoutFlags="XProportional,YProportional,WidthProportional"
               BackgroundColor="#1A1A2E"
               CornerRadius="20,20,0,0"
               Padding="16"
               HasShadow="True">
            <VerticalStackLayout Spacing="12">
                <!-- Drag Handle -->
                <BoxView HeightRequest="4"
                        WidthRequest="40"
                        CornerRadius="2"
                        Color="#3D3D5C"
                        HorizontalOptions="Center" />

                <!-- Activity Chip Row -->
                <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Frame BackgroundColor="#2A2A3E"
                           CornerRadius="16"
                           Padding="12,6">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="🏃" 
                                   FontSize="16" />
                            <Label Text="{Binding CurrentActivity}" 
                                   TextColor="#FFFFFF"
                                   FontSize="14" />
                        </HorizontalStackLayout>
                    </Frame>
                    
                    <Label Text="{Binding SpeedString}" 
                           TextColor="#00C896"
                           FontSize="14"
                           VerticalOptions="Center" />
                    
                    <Label Text="{Binding TotalDistanceKm, StringFormat='{0:F2} km'}" 
                           TextColor="#6C63FF"
                           FontSize="14"
                           VerticalOptions="Center" />
                    
                    <Label Text="{Binding DurationString}" 
                           TextColor="#99FFFFFF"
                           FontSize="14"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- Stats Grid -->
                <Grid ColumnDefinitions="*,*,*" 
                      RowDefinitions="Auto,Auto"
                      RowSpacing="8"
                      ColumnSpacing="12">
                    <VerticalStackLayout Grid.Row="0" Grid.Column="0" HorizontalOptions="Center">
                        <Label Text="Distance" TextColor="#99FFFFFF" FontSize="10" />
                        <Label Text="{Binding TotalDistanceKm, StringFormat='{0:F1} km'}" 
                               TextColor="#FFFFFF"
                               FontAttributes="Bold" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Row="0" Grid.Column="1" HorizontalOptions="Center">
                        <Label Text="Duration" TextColor="#99FFFFFF" FontSize="10" />
                        <Label Text="{Binding DurationString}" 
                               TextColor="#FFFFFF"
                               FontAttributes="Bold" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Row="0" Grid.Column="2" HorizontalOptions="Center">
                        <Label Text="Max Speed" TextColor="#99FFFFFF" FontSize="10" />
                        <Label Text="{Binding CurrentSession.MaxSpeedMps, StringFormat='{0:F1} m/s', FallbackValue='--'}" 
                               TextColor="#FFFFFF"
                               FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>
        </Frame>

    </AbsoluteLayout>

</ContentPage>
