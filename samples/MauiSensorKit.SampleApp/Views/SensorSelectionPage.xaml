<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiSensorKit.SampleApp.ViewModels"
             x:Class="MauiSensorKit.SampleApp.Views.SensorSelectionPage"
             Title="Configure Sensors">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Padding="15">
        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="0,10" Spacing="5">
            <Label Text="Configure Sensors"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
            <Label Text="Enable sensors to collect data"
                   FontSize="14"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Action Buttons -->
        <HorizontalStackLayout Grid.Row="1" Spacing="10" HorizontalOptions="Center" Padding="0,10">
            <Button Text="Auto Select Available"
                    Command="{Binding AutoSelectAvailableCommand}"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    Padding="15,8"
                    FontSize="13" />
            <Button Text="Enable All"
                    Command="{Binding EnableAllCommand}"
                    BackgroundColor="#28A745"
                    TextColor="White"
                    Padding="15,8"
                    FontSize="13" />
            <Button Text="Disable All"
                    Command="{Binding DisableAllCommand}"
                    BackgroundColor="#DC3545"
                    TextColor="White"
                    Padding="15,8"
                    FontSize="13" />
        </HorizontalStackLayout>

        <!-- Status Summary -->
        <Border Grid.Row="2"
                BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                Padding="15,10"
                Margin="10,5"
                Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray700}}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="5">
                <Label Text="{Binding StatusSummary}"
                       FontSize="13"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label Text="Green = Available | Yellow = Needs Permission | Red = Unavailable"
                       FontSize="11"
                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Border>

        <!-- Sensor List -->
        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding GroupedSensors}"
                        IsGrouped="True">
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray800}}"
                            Padding="15,8"
                            Margin="10,5">
                        <Label Text="{Binding Name}"
                               FontSize="16"
                               FontAttributes="Bold" />
                    </Border>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="15,10"
                            Margin="10,2"
                            Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray700}}"
                            StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                            <!-- Icon -->
                            <Image Grid.Column="0"
                                   Source="{Binding Icon}"
                                   WidthRequest="32"
                                   HeightRequest="32"
                                   Aspect="AspectFit" />

                            <!-- Info -->
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="{Binding Name}"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding Description}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="{Binding AvailabilityLabel}"
                                           FontSize="11"
                                           TextColor="{Binding AvailabilityColor}"
                                           FontAttributes="Italic" />
                                    <Label IsVisible="{Binding NeedsPermission}"
                                           Text="|"
                                           FontSize="11"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray600}}" />
                                    <Label IsVisible="{Binding NeedsPermission}"
                                           Text="{Binding RequiredPermissions, StringFormat='Needs: {0}'}"
                                           FontSize="11"
                                           TextColor="#FF9800"
                                           FontAttributes="Italic" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <!-- Toggle or Permission Button -->
                            <Grid Grid.Column="2" ColumnDefinitions="Auto,Auto" ColumnSpacing="5">
                                <!-- Toggle for available sensors -->
                                <Switch Grid.Column="0"
                                        IsVisible="{Binding CanBeToggled}"
                                        IsToggled="{Binding IsEnabled, Mode=TwoWay}"
                                        IsEnabled="{Binding IsAvailable}"
                                        VerticalOptions="Center" />

                                <!-- Permission button for sensors needing permission -->
                                <Button Grid.Column="1"
                                        IsVisible="{Binding NeedsPermission}"
                                        Text="Allow"
                                        FontSize="11"
                                        Padding="10,6"
                                        BackgroundColor="#FF9800"
                                        TextColor="White"
                                        Command="{Binding BindingContext.RequestPermissionCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                        CommandParameter="{Binding .}"
                                        VerticalOptions="Center" />
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Footer -->
        <Button Grid.Row="4"
                Text="Save &amp; Continue"
                Command="{Binding SaveSelectionCommand}"
                Margin="20"
                Padding="15"
                FontSize="16"
                BackgroundColor="{StaticResource Primary}" />
    </Grid>

</ContentPage>
