<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:MauiSensorKit.SampleApp.Views"
       x:Class="MauiSensorKit.SampleApp.AppShell"
       Title="SensorKit"
       BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#0F0F1A}"
       ForegroundColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
       TitleColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
       NavBarIsVisible="True"
       FlyoutBehavior="Flyout"
       FlyoutBackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1A1A2E}"
       FlyoutWidth="280">

    <!-- Flyout Header -->
    <Shell.FlyoutHeader>
        <Grid BackgroundColor="#6C63FF" HeightRequest="140" Padding="20">
            <VerticalStackLayout VerticalOptions="Center" Spacing="8">
                <Label Text="📱" FontSize="40" HorizontalOptions="Start"/>
                <Label Text="SensorKit" 
                       TextColor="#FFFFFF" 
                       FontSize="24" 
                       FontAttributes="Bold"/>
                <Label Text="Advanced Sensor Analytics" 
                       TextColor="#E0E0E0" 
                       FontSize="12"/>
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <!-- Flyout Items with FontImage icons -->
    <FlyoutItem Title="Dashboard">
        <FlyoutItem.Icon>
            <FontImageSource Glyph="🏠" FontFamily="Emoji" Size="24"/>
        </FlyoutItem.Icon>
        <ShellContent ContentTemplate="{DataTemplate local:DashboardPage}" Route="dashboard"/>
    </FlyoutItem>

    <FlyoutItem Title="Motion Sensors">
        <FlyoutItem.Icon>
            <FontImageSource Glyph="📊" FontFamily="Emoji" Size="24"/>
        </FlyoutItem.Icon>
        <ShellContent ContentTemplate="{DataTemplate local:MotionSensorsPage}" Route="sensors"/>
    </FlyoutItem>

    <FlyoutItem Title="Activity Recognition">
        <FlyoutItem.Icon>
            <FontImageSource Glyph="🏃" FontFamily="Emoji" Size="24"/>
        </FlyoutItem.Icon>
        <ShellContent ContentTemplate="{DataTemplate local:ActivityRecognitionPage}" Route="activity"/>
    </FlyoutItem>

    <FlyoutItem Title="Live Route Map">
        <FlyoutItem.Icon>
            <FontImageSource Glyph="🗺️" FontFamily="Emoji" Size="24"/>
        </FlyoutItem.Icon>
        <ShellContent ContentTemplate="{DataTemplate local:MapPage}" Route="map"/>
    </FlyoutItem>

    <FlyoutItem Title="Battery Analytics">
        <FlyoutItem.Icon>
            <FontImageSource Glyph="🔋" FontFamily="Emoji" Size="24"/>
        </FlyoutItem.Icon>
        <ShellContent ContentTemplate="{DataTemplate local:BatteryPage}" Route="battery"/>
    </FlyoutItem>

    <FlyoutItem Title="Sensor Setup">
        <FlyoutItem.Icon>
            <FontImageSource Glyph="⚙️" FontFamily="Emoji" Size="24"/>
        </FlyoutItem.Icon>
        <ShellContent ContentTemplate="{DataTemplate local:SensorSelectionPage}" Route="setup"/>
    </FlyoutItem>

    <!-- Separator -->
    <MenuItem Text="──────────────" IsEnabled="False"/>

    <!-- Version Info Footer -->
    <Shell.FlyoutFooter>
        <Grid BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#0F0F1A}" Padding="20" HeightRequest="60">
            <Label Text="v1.1.0 • ZenithCode" 
                   TextColor="{AppThemeBinding Light=#666666, Dark=#6B6B8A}" 
                   FontSize="11"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
        </Grid>
    </Shell.FlyoutFooter>

</Shell>
