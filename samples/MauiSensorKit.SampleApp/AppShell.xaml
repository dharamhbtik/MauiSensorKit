<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:MauiSensorKit.SampleApp.Views"
       x:Class="MauiSensorKit.SampleApp.AppShell"
       Title="MauiSensorKit"
       BackgroundColor="#0F0F1A"
       ForegroundColor="#FFFFFF"
       TitleColor="#FFFFFF"
       TabBarBackgroundColor="#1A1A2E"
       TabBarForegroundColor="#6C63FF"
       TabBarUnselectedColor="#6B6B8A"
       TabBarTitleColor="#6C63FF"
       NavBarIsVisible="False">

    <!-- 6-Tab Bottom Navigation -->
    <TabBar>
        <!-- Tab 1: Dashboard (Home) -->
        <Tab Title="Home" Icon="🏠">
            <ShellContent ContentTemplate="{DataTemplate local:DashboardPage}" 
                         Route="dashboard" />
        </Tab>

        <!-- Tab 2: Motion Sensors with Graphs -->
        <Tab Title="Sensors" Icon="📊">
            <ShellContent ContentTemplate="{DataTemplate local:MotionSensorsPage}" 
                         Route="sensors" />
        </Tab>

        <!-- Tab 3: Activity Recognition -->
        <Tab Title="Activity" Icon="🏃">
            <ShellContent ContentTemplate="{DataTemplate local:ActivityRecognitionPage}" 
                         Route="activity" />
        </Tab>

        <!-- Tab 4: Live Route Map -->
        <Tab Title="Map" Icon="🗺️">
            <ShellContent ContentTemplate="{DataTemplate local:MapPage}" 
                         Route="map" />
        </Tab>

        <!-- Tab 5: Battery Analytics -->
        <Tab Title="Battery" Icon="🔋">
            <ShellContent ContentTemplate="{DataTemplate local:BatteryPage}" 
                         Route="battery" />
        </Tab>

        <!-- Tab 6: Setup/Sensor Configuration -->
        <Tab Title="Setup" Icon="⚙️">
            <ShellContent ContentTemplate="{DataTemplate local:SensorSelectionPage}" 
                         Route="setup" />
        </Tab>
    </TabBar>

</Shell>
